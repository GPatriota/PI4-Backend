# Database
SQLITE_DB_PATH=./data/electroshop.db

# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_ACCESS_SECRET=your-super-secret-access-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
ALLOWED_ORIGINS=http://localhost:8081,exp://192.168.1.100:8081

# Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MERCADO_PAGO_SUCCESS_URL=electroshop://payment/success
MERCADO_PAGO_FAILURE_URL=electroshop://payment/failure
MERCADO_PAGO_PENDING_URL=electroshop://payment/pending
MERCADO_PAGO_WEBHOOK_URL=https://your-public-api-domain.com/api/v1/orders/checkout/webhook

# Cloudinary (optional, for documentation)
CLOUDINARY_CLOUD_NAME=djo2iaa9m
CLOUDINARY_UPLOAD_PRESET=electroshop_products
